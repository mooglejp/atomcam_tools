 // By default, use INADDR_ANY for the sending and receiving interfaces (IPv4 only):
 ipv4AddressBits SendingInterfaceAddr = INADDR_ANY;
 ipv4AddressBits ReceivingInterfaceAddr = INADDR_ANY;
 in6_addr ReceivingInterfaceAddr6 = IN6ADDR_ANY_INIT;
+
+static void setSocketDscpFromEnv(int socket, int domain) {
+  char const* value = getenv("LIVE555_DSCP");
+  if (value == NULL || value[0] == 0) return;
+
+  char* end = NULL;
+  long dscp = strtol(value, &end, 10);
+  if (end == value || dscp < 0 || dscp > 63) return;
+
+  int tos = ((int)dscp) << 2;
+  if (domain == AF_INET) {
+#ifdef IP_TOS
+    (void)setsockopt(socket, IPPROTO_IP, IP_TOS, (const char*)&tos, sizeof tos);
+#endif
+  }
+#ifdef IPV6_TCLASS
+  else if (domain == AF_INET6) {
+    (void)setsockopt(socket, IPPROTO_IPV6, IPV6_TCLASS, (const char*)&tos, sizeof tos);
+  }
+#endif
+}
