#!/bin/sh
#
# set sshd authorized_keys
#


case "$1" in
  start)
    mkdir -p /root/.ssh
    chmod 700 /root/.ssh
    if [ -f /media/mmc/authorized_keys ] ; then
      cp /media/mmc/authorized_keys /root/.ssh
      chmod 600 /root/.ssh/authorized_keys
    fi
	;;
  stop)
	;;
  restart|reload)
    "$0" stop
    "$0" start
	;;
  *)
	echo "Usage: $0 {start|stop|restart}"
	exit 1
esac

exit $?

